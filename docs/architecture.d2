# AI CRM Agent - Architecture (v5: linear L-to-R flow, stacked core)
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
}

# Layout: [entry] -> [core: Data / App / Integrations stacked] -> [processing]

entry_slot: "" { class: hidden
  user: Internal User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

core: "" { class: hidden
  direction: down

  data_zone: "Data" {
    grid-columns: 1
    grid-gap: 80

    db: Postgres {
      class: card
      icon: https://cdn.simpleicons.org/postgresql
    }
  }

  app_zone: "App" {
    grid-columns: 2
    grid-gap: 80

    ui: Next.js Frontend {
      class: card
      icon: https://cdn.simpleicons.org/nextdotjs
    }
    orchestrator: FastAPI Backend {
      class: card
      icon: https://cdn.simpleicons.org/fastapi
    }
  }

  integrations_zone: "3rd Party Integrations" {
    grid-columns: 3
    grid-gap: 80

    claude: Claude API {
      class: card
      icon: https://cdn.simpleicons.org/anthropic
    }
    hubspot: HubSpot {
      class: card
      icon: https://cdn.simpleicons.org/hubspot
    }
    salesforce: Salesforce {
      class: card
      icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cloud.svg
    }
  }
}

processing_zone: "Agent Runtime" {
  grid-columns: 1
  grid-gap: 80

  memory: Memory Manager {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/brain.svg
  }
  reads: Read Tools {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/eye.svg
  }
  writes: Write Guardrail {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg
  }
}

# Zone-to-zone arrows only. Max 6. Linear flow.
entry_slot.user -> core.app_zone: "1. Message"
core.app_zone -> core.data_zone: "2. Load session"
core.app_zone -> processing_zone: "3. Tool calls"
processing_zone -> core.integrations_zone: "4. Read/Write CRM" {
  style.stroke: "#059669"
  style.bold: true
}
core.app_zone -> core.integrations_zone.claude: "LLM call" {
  style.stroke-dash: 3
}
